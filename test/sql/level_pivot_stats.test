# name: test/sql/level_pivot_stats.test
# description: level_pivot_stats() exposes write/put/delete counters
# group: [sql]

require level_pivot

statement ok
ATTACH '__TEST_DIR__/stats_db' AS s (TYPE level_pivot, READ_ONLY false, CREATE_IF_MISSING true);

statement ok
CALL level_pivot_create_table('s', 'kv', NULL, ['key', 'value'], table_mode := 'raw');

# Baseline counters: zero
query III
SELECT total_writes, total_puts, total_deletes FROM level_pivot_stats('s');
----
0	0	0

# Single INSERT: +1 write, +1 put
statement ok
INSERT INTO s.kv VALUES ('a', '1');

query III
SELECT total_writes, total_puts, total_deletes FROM level_pivot_stats('s');
----
1	1	0

# Multi-row INSERT counts as ONE write but multiple puts (regression guard:
# if someone splits the batch this assertion fires)
statement ok
INSERT INTO s.kv VALUES ('b', '2'), ('c', '3'), ('d', '4');

query III
SELECT total_writes, total_puts, total_deletes FROM level_pivot_stats('s');
----
2	4	0

# DELETE: +1 write, +1 delete
statement ok
DELETE FROM s.kv WHERE key = 'a';

query III
SELECT total_writes, total_puts, total_deletes FROM level_pivot_stats('s');
----
3	4	1

statement ok
DETACH s;
